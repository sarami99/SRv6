name: cherry-ai-lab

topology:
  nodes:
    # --- Juniper Core (Logical Systems) ---
    juniper-core:
      kind: juniper_vjunosrouter
      image: vrnetlab/juniper_vjunos-router:25.4R1.12
      startup-config: ./configs/juniper-core.conf

    # --- Ubuntu Hosts (Edge PE) ---
    ubuntu01:
      kind: linux
      image: cherry-srv6-node:latest
      binds:
        - ./configs/ubuntu01_frr.conf:/etc/frr/frr.conf
      exec:
        # Create the VLAN subinterfaces on boot
        - ip link add link eth1 name eth1.11 type vlan id 11
        - ip link set dev eth1.11 up
        - ip link add link eth1 name eth1.12 type vlan id 12
        - ip link set dev eth1.12 up
     # exec:
     #   - sysctl -w net.ipv6.conf.all.forwarding=1
     #   - sysctl -w net.ipv6.conf.all.seg6_enabled=1
     #   - service frr restart
     #   - /usr/local/bin/cherry-agent &
    ubuntu02:
      kind: linux
      image: cherry-srv6-node:latest
      binds:
        - ./configs/ubuntu02_frr.conf:/etc/frr/frr.conf
     # exec:
     #   - sysctl -w net.ipv6.conf.all.forwarding=1
     #   - sysctl -w net.ipv6.conf.all.seg6_enabled=1
     #   - service frr restart
     #   - /usr/local/bin/cherry-agent &

    # --- Whitebox Linux PE ---
    linux01:
      kind: linux
      image: cherry-srv6-node:latest
